# Resend — transactional email for contact/commission/acquisition/contribution forms.
# When unset, form submissions are logged to the server console instead of sent (safe for local dev).
RESEND_API_KEY=
CONTACT_EMAIL=hello@lucsan.com

# Upstash Redis — sliding-window rate limiting (5 requests / 10 min per IP) for all inquiry forms.
# When unset, rate limiting is inactive and a console warning is logged.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
